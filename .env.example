# API (production: Railway backend URL, not Vercel site)
VITE_API_URL=http://localhost:3000

# Supabase
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (web)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Auth redirects (production)
# Set this to your deployed customer web URL so confirmation emails don't redirect to localhost.
VITE_SITE_URL=https://kolia-customer.vercel.app

# Optional base path (keep "/" for root domain deployment)
# Examples:
# VITE_BASE=/
# VITE_BASE=/customer/
# VITE_VERCEL_ORIGIN is injected automatically at build on Vercel.

# Optional: force a single language (en, fr, pt). When set, the in-app language
# switcher is disabled and this locale is always used.
# If omitted: saved preference (localStorage) then browser language.
# VITE_LOCALE=en

